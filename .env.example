# MongoDB
MONGO_USER=blogadmin
MONGO_PASSWORD=change_me_strong_password
MONGODB_DB_NAME=personal_blog

# Backend reads this URL — note password must be URL-encoded if it contains special chars
MONGODB_URL=mongodb://blogadmin:change_me_strong_password@blog-mongodb:27017/?authSource=admin

# JWT — generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_a_random_32byte_hex_string

# Frontend allowed origins (comma-separated)
CORS_ORIGINS=https://your-domain.com,http://localhost

# Admin user (used by scripts/import_articles.py to seed first user)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password
